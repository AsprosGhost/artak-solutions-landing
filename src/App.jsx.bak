function ProjectVisual({ theme, type }) {
  const visuals = {
    dashboard: <DashboardVisual />,
    mobile: <MobileVisual />,
    analytics: <AnalyticsVisual />,
    finance: <FinanceVisual />,
  }

  return (
    <div className={`project-visual ${theme}`}>
      <div className="project-glass" />
      {visuals[type]}
    </div>
  )
}

