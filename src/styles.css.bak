:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #f8fbff;
  background: #020713;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  --bg: #020713;
  --bg-2: #071020;
  --card: rgba(12, 24, 43, 0.82);
  --card-2: rgba(17, 31, 54, 0.84);
  --line: rgba(255, 255, 255, 0.12);
  --muted: #9aa7bb;
  --muted-2: #c2cada;
  --white: #f7fbff;
  --red: #fb2f4c;
  --red-2: #d7192e;
  --purple: #8d4dff;
  --blue: #5c7cff;
  --green: #27cf76;
  --shadow: 0 26px 90px rgba(0, 0, 0, 0.36);
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% 17%, rgba(59, 94, 255, 0.10), transparent 28%),
    radial-gradient(circle at 76% 21%, rgba(244, 32, 70, 0.14), transparent 24%),
    radial-gradient(circle at 78% 76%, rgba(92, 124, 255, 0.10), transparent 25%),
    linear-gradient(135deg, #050a15 0%, #030611 45%, #020713 100%);
  overflow-x: hidden;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(rgba(255,255,255,0.023) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
  background-size: 84px 84px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,.42), transparent 75%);
  z-index: -1;
}

body::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(circle at 50% 0%, transparent 0%, rgba(1, 5, 12, 0.42) 69%);
  z-index: -1;
}

button, a { font: inherit; }

a { color: inherit; text-decoration: none; }

button { cursor: pointer; }

.container {
  width: min(100% - 48px, 1160px);
  margin: 0 auto;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 30;
  border-bottom: 1px solid rgba(255,255,255,.06);
  background: rgba(2, 7, 19, 0.78);
  backdrop-filter: blur(18px);
}

.nav {
  min-height: 76px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.logo {
  display: inline-flex;
  align-items: baseline;
  gap: 0;
  font-weight: 900;
  letter-spacing: -0.055em;
  font-size: clamp(1.24rem, 2vw, 1.58rem);
  white-space: nowrap;
}

.logo-red { color: var(--red); }

.logo span:last-child { margin-left: 5px; letter-spacing: -0.045em; }

.desktop-nav {
  display: flex;
  gap: clamp(20px, 3.1vw, 56px);
  align-items: center;
  font-size: .9rem;
  color: #d7deeb;
}

.desktop-nav a { position: relative; transition: color .2s; }
.desktop-nav a:hover { color: #fff; }
.desktop-nav a::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -9px;
  height: 2px;
  border-radius: 999px;
  background: var(--red);
  transform: scaleX(0);
  transform-origin: center;
  transition: transform .22s;
}
.desktop-nav a:hover::after { transform: scaleX(1); }

.nav-cta,
.btn {
  border: 1px solid rgba(255,255,255,.28);
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  min-height: 56px;
  padding: 0 26px;
  font-weight: 850;
  letter-spacing: -0.025em;
  transition: transform .22s, border-color .22s, background .22s, box-shadow .22s;
}

.nav-cta { min-height: 48px; }
.nav-cta:hover,
.btn:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.72); }

.mobile-menu {
  display: none;
  color: #fff;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 14px;
  place-items: center;
  width: 46px;
  height: 46px;
}

.mobile-panel {
  display: none;
  border-top: 1px solid rgba(255,255,255,.08);
  background: rgba(2, 7, 19, 0.96);
  box-shadow: 0 30px 80px rgba(0,0,0,.45);
}

.mobile-nav {
  display: grid;
  gap: 4px;
  padding-top: 18px;
  padding-bottom: 22px;
}

.mobile-nav a:not(.btn) {
  border-radius: 14px;
  color: #dbe3f2;
  padding: 14px 12px;
  font-weight: 750;
}
.mobile-nav a:not(.btn):hover { background: rgba(255,255,255,.06); color: #fff; }
.mobile-nav .btn { margin-top: 10px; width: 100%; }

.hero {
  position: relative;
  overflow: hidden;
  padding: clamp(60px, 7vw, 92px) 0 28px;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(circle at 76% 46%, rgba(251, 47, 76, .14), transparent 29%);
}

.hero-grid {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.02fr) minmax(440px, .98fr);
  align-items: center;
  gap: clamp(36px, 6vw, 80px);
}

.hero-copy { max-width: 650px; }

.eyebrow,
.section-kicker {
  color: #8493ff;
  text-transform: uppercase;
  letter-spacing: .18em;
  font-size: .78rem;
  font-weight: 900;
  margin: 0 0 26px;
}

.centered { text-align: center; }

h1, h2, h3, p { margin-top: 0; }

.hero h1 {
  color: var(--white);
  letter-spacing: -0.082em;
  line-height: .98;
  margin-bottom: 28px;
  font-size: clamp(4.1rem, 6.35vw, 6.5rem);
  font-weight: 950;
}

.hero h1 span { color: var(--red); display: block; }

.hero-text {
  color: var(--muted-2);
  max-width: 590px;
  margin-bottom: 36px;
  font-size: 1.02rem;
  line-height: 1.85;
}

.hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.btn-primary {
  border-color: transparent;
  color: #fff;
  background: linear-gradient(135deg, var(--red), #e01b35);
  box-shadow: 0 20px 60px rgba(251, 47, 76, .24);
}
.btn-primary:hover { box-shadow: 0 28px 76px rgba(251, 47, 76, .34); }
.btn-secondary { color: #fff; background: rgba(255,255,255,.02); }

.trust-points {
  display: flex;
  gap: clamp(18px, 3vw, 38px);
  align-items: center;
  flex-wrap: wrap;
  margin-top: 64px;
  color: #c4cde0;
  font-size: .86rem;
  font-weight: 800;
}
.trust-points span { display: inline-flex; align-items: center; gap: 10px; }
.trust-points svg { color: #e9efff; }

.phone-scene {
  position: relative;
  width: min(100%, 620px);
  min-height: 590px;
  justify-self: end;
}

.glow { position: absolute; border-radius: 999px; filter: blur(20px); opacity: .55; }
.glow-red { right: 70px; bottom: 28px; width: 250px; height: 250px; background: rgba(251, 47, 76, .22); }
.glow-blue { left: 60px; top: 96px; width: 230px; height: 230px; background: rgba(92, 124, 255, .14); }
.dots {
  position: absolute;
  top: 50px;
  right: 52px;
  width: 150px;
  height: 110px;
  opacity: .33;
  background-image: radial-gradient(circle, rgba(255,255,255,.24) 1px, transparent 1.4px);
  background-size: 15px 15px;
}

.phone {
  position: absolute;
  border: 9px solid #212938;
  background: linear-gradient(155deg, #122039, #07111f 54%, #050b15);
  border-radius: 42px;
  box-shadow: 0 32px 90px rgba(0,0,0,.46), inset 0 1px rgba(255,255,255,.14);
  overflow: hidden;
}
.phone::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background: linear-gradient(120deg, rgba(255,255,255,.18), transparent 22%, transparent 75%, rgba(255,255,255,.07));
}
.phone-front { width: 272px; height: 542px; left: 55px; top: 28px; z-index: 2; transform: rotate(-2.5deg); }
.phone-back { width: 280px; height: 500px; right: 34px; top: 112px; opacity: .82; transform: rotate(1.5deg); }
.phone-notch { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 76px; height: 24px; background: #030711; border-radius: 0 0 18px 18px; }
.mini-status { display: flex; justify-content: space-between; align-items: center; padding: 27px 23px 0; color: #d9e8ff; font-size: .77rem; font-weight: 900; }
.hello-row { display: flex; justify-content: space-between; align-items: center; padding: 48px 23px 0; color: #e4edff; font-weight: 800; }
.hello-row div { background: rgba(255,255,255,.1); border-radius: 15px; display: grid; place-items: center; width: 35px; height: 35px; }
.balance { padding: 27px 23px 0; }
.balance span, .growth-card span { color: #94a3ba; display: block; font-size: .78rem; }
.balance strong { display: block; margin-top: 8px; font-size: 1.6rem; letter-spacing: -0.06em; }
.balance em { color: var(--green); font-size: 1.08rem; font-style: normal; }
.balance small { color: var(--green); font-weight: 800; display: block; margin-top: 7px; }
.quick-actions { padding: 28px 22px 0; display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; }
.quick-actions button { color: #fff; background: rgba(255,255,255,.075); border: 1px solid rgba(255,255,255,.06); border-radius: 15px; height: 62px; font-weight: 900; }
.quick-actions span { display: block; margin-top: 8px; color: #d9e4f5; font-size: .6rem; }
.account-list { padding: 24px 22px 0; }
.account-list p, .movement p { margin: 0 0 12px; font-size: .76rem; font-weight: 900; color: #f0f6ff; }
.account-item { display: grid; grid-template-columns: 24px 1fr auto; align-items: center; gap: 12px; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.055); border-radius: 15px; margin-bottom: 10px; padding: 14px; font-size: .67rem; }
.account-item small { color: #8999b0; }
.account-item b { font-size: .7rem; }
.green { color: var(--green); }
.bullet { width: 18px; height: 18px; border-radius: 7px; }
.bullet.purple { background: var(--purple); }
.bullet.orange { background: #ff7047; }
.movement { padding: 18px 22px 0; }
.movement-row { display: flex; justify-content: space-between; color: #9aa8bd; background: rgba(39, 207, 118, .08); padding: 12px; border-radius: 14px; font-size: .67rem; }
.movement-row b { color: var(--green); }
.growth-card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.075); border-radius: 24px; margin: 92px 24px 0; padding: 20px; }
.growth-card strong { color: var(--green); display: block; margin-top: 8px; }
.chart-line { height: 92px; margin-top: 22px; border-radius: 16px; background: linear-gradient(140deg, transparent 0 21%, rgba(91,124,255,.55) 21% 23%, transparent 23% 35%, rgba(91,124,255,.78) 35% 37%, transparent 37% 50%, rgba(91,124,255,.6) 50% 52%, transparent 52% 69%, rgba(39,207,118,.75) 69% 71%, transparent 71%) 0 0/100% 100%, linear-gradient(0deg, rgba(255,255,255,.07) 1px, transparent 1px) 0 0/100% 22px; }
.mini-list { display: grid; grid-template-columns: 1fr auto; gap: 14px 16px; margin: 32px 28px; color: #9da8bb; font-size: .76rem; }
.mini-list b { color: #e9effc; }
.mini-list b:first-of-type { color: #25cf75; }

.client-strip { padding: 30px 0 58px; border-top: 1px solid rgba(255,255,255,.08); border-bottom: 1px solid rgba(255,255,255,.06); }
.client-strip .section-kicker { margin-bottom: 28px; }
.client-logos { display: grid; grid-template-columns: repeat(5,1fr); gap: 28px; align-items: center; color: rgba(255,255,255,.78); }
.client-logos > span { min-height: 58px; display: flex; align-items: center; justify-content: center; filter: grayscale(1); opacity: .9; }
.dish-logo { font-family: Georgia, serif; font-size: 3rem; letter-spacing: -.09em; }
.somos-logo { gap: 8px; font-size: 3.3rem; font-weight: 900; }
.somos-logo small { line-height: .88; letter-spacing: .04em; font-size: .88rem; }
.nomibox-logo { font-weight: 900; font-size: 2.28rem; letter-spacing: -.07em; }
.variv-logo { flex-direction: column; font-family: Georgia, serif; font-size: 2.18rem; letter-spacing: .23em; }
.variv-logo small { font-family: inherit; font-size: .66rem; letter-spacing: .34em; }
.more-logo { color: rgba(255,255,255,.70); font-size: 1.25rem; }

.section { padding: 96px 0 0; }
.services-grid { display: grid; grid-template-columns: 340px minmax(0,1fr); gap: clamp(44px, 7vw, 90px); align-items: start; }
.section-copy h2, .work h2, .process-section h2 { font-size: clamp(2.4rem, 4.2vw, 3.65rem); line-height: 1; letter-spacing: -.07em; margin-bottom: 0; }
.section-copy p:not(.section-kicker) { color: var(--muted-2); line-height: 1.85; margin: 28px 0 30px; }
.text-link, .mini-link, .project-content a { display: inline-flex; align-items: center; gap: 8px; color: #8798ff; font-weight: 850; }
.service-cards { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 14px; }
.service-card { min-height: 218px; border: 1px solid var(--line); border-radius: 14px; background: linear-gradient(145deg, rgba(19,34,58,.9), rgba(9,18,34,.82)), radial-gradient(circle at 0 0, rgba(255,255,255,.10), transparent 25%); padding: 34px 32px 28px; box-shadow: inset 0 1px rgba(255,255,255,.05); transition: transform .24s, border-color .24s, background .24s; }
.service-card:hover { transform: translateY(-5px); border-color: rgba(255,255,255,.24); background: linear-gradient(145deg, rgba(24,43,73,.95), rgba(11,22,41,.9)); }
.icon-badge, .process-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 15px; color: #fff; box-shadow: 0 14px 36px rgba(0,0,0,.32); }
.icon-badge.red, .process-icon.red { background: linear-gradient(135deg,#ff3a58,#d80f2a); }
.icon-badge.purple, .process-icon.purple { background: linear-gradient(135deg,#a157ff,#6324dc); }
.icon-badge.blue, .process-icon.blue { background: linear-gradient(135deg,#7290ff,#3153df); }
.icon-badge.green, .process-icon.green { background: linear-gradient(135deg,#36e285,#16a85a); }
.service-card h3 { margin: -42px 0 22px 66px; font-size: 1.2rem; letter-spacing: -.045em; }
.service-card p { margin: 0 0 28px 66px; color: var(--muted); font-size: .92rem; line-height: 1.75; }
.service-card .mini-link { margin-left: 66px; font-size: .86rem; }
.mini-link.red { color: var(--red); }
.mini-link.purple { color: var(--purple); }
.mini-link.blue { color: #7890ff; }
.mini-link.green { color: var(--green); }

.work-head { display: flex; justify-content: space-between; align-items: end; gap: 24px; margin-bottom: 28px; }
.work h2 { max-width: 380px; }
.slider-buttons { display: flex; gap: 14px; }
.slider-buttons button { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 999px; color: #fff; background: transparent; border: 1px solid rgba(255,255,255,.36); }
.project-grid { display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap: 22px; }
.project-card { min-height: 388px; overflow: hidden; border: 1px solid var(--line); border-radius: 13px; background: linear-gradient(rgba(15,31,54,.92), rgba(7,16,32,.96)); box-shadow: 0 24px 72px rgba(0,0,0,.23); transition: transform .24s, border-color .24s; }
.project-card:hover { transform: translateY(-5px); border-color: rgba(255,255,255,.26); }
.project-visual { position: relative; height: 178px; overflow: hidden; background: radial-gradient(circle at 50% 10%, rgba(255,255,255,.22), transparent 44%), linear-gradient(145deg, rgba(255,255,255,.16), rgba(255,255,255,.04)); }
.project-glass { position: absolute; inset: 0; background: linear-gradient(180deg, transparent, rgba(2,7,19,.18)); z-index: 4; }
.project-red { background-color: rgba(246,48,78,.10); }
.project-blue { background-color: rgba(62,98,255,.12); }
.project-white { background-color: rgba(255,255,255,.10); }
.project-gray { background-color: rgba(183,191,202,.12); }
.dashboard-mock, .analytics-mock, .finance-mock, .two-phones { position: absolute; inset: 22px 20px 0; }
.dashboard-mock { display: grid; grid-template-columns: 56px 1fr; gap: 12px; transform: perspective(500px) rotateX(7deg); }
.dash-sidebar, .dash-main, .analytics-window, .finance-panel, .case-phone { background: linear-gradient(145deg, #eef4ff, #ccd7e9); border: 1px solid rgba(255,255,255,.42); box-shadow: 0 22px 45px rgba(0,0,0,.27); }
.dash-sidebar { border-radius: 18px 18px 0 0; padding: 14px 10px; display: grid; gap: 12px; align-content: start; }
.dash-sidebar span, .dash-top, .dash-cards i, .dash-chart, .case-phone span, .case-phone i, .analytics-window span, .finance-list i { background: #b9c5d7; border-radius: 5px; }
.dash-main { border-radius: 8px 8px 0 0; padding: 14px; }
.dash-top { height: 16px; margin-bottom: 12px; }
.dash-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: 12px; }
.dash-cards i { height: 24px; }
.dash-chart { position: relative; height: 50px; overflow: hidden; }
.dash-chart::after { content:""; position:absolute; inset: 16px 18px; background: linear-gradient(145deg, transparent 0 22%, #6d86ff 22% 25%, transparent 25% 43%, #ff5f8b 43% 46%, transparent 46% 70%, #25cf75 70% 73%, transparent 73%); }
.two-phones { display: flex; align-items: end; justify-content: center; gap: 8px; }
.case-phone { width: 88px; height: 150px; border-radius: 20px 20px 0 0; padding: 24px 12px 12px; display: grid; gap: 9px; align-content: start; }
.case-phone-b { height: 132px; opacity: .88; transform: translateY(14px) rotate(4deg); }
.case-phone-a { transform: rotate(-5deg); }
.case-phone span { height: 13px; }
.case-phone span:nth-child(2) { width: 76%; }
.case-phone i { height: 34px; background: linear-gradient(135deg, #9aaeff, #e7ecf6); }
.analytics-mock { display: grid; grid-template-columns: 1.35fr .9fr; align-items: end; gap: 12px; }
.analytics-window { border-radius: 12px 12px 0 0; padding: 16px; }
.analytics-window.big { height: 116px; }
.analytics-window.small { height: 94px; opacity: .86; }
.analytics-window span { display: block; height: 14px; margin-bottom: 14px; }
.analytics-window div { display: grid; grid-template-columns: repeat(3,1fr); align-items: end; gap: 8px; height: 50px; }
.analytics-window i { background: linear-gradient(180deg, #869cff, #f1f5ff); border-radius: 6px 6px 0 0; }
.analytics-window i:nth-child(1) { height: 52%; }
.analytics-window i:nth-child(2) { height: 82%; }
.analytics-window i:nth-child(3) { height: 62%; }
.finance-mock { display: grid; grid-template-columns: 1fr .72fr; gap: 14px; align-items: end; }
.finance-panel { height: 116px; border-radius: 18px 18px 0 0; padding: 22px; display: grid; align-content: center; color: #10203c; }
.finance-panel svg { color: #5c7cff; }
.finance-panel span { margin-top: 6px; color: #647084; font-size: .72rem; font-weight: 800; }
.finance-panel b { color: #23b86b; font-size: 1.4rem; }
.finance-list { display: grid; gap: 10px; padding-bottom: 18px; }
.finance-list i { height: 24px; }
.project-content { padding: 29px 24px 26px; }
.project-content h3 { display: flex; flex-direction: column; justify-content: center; min-height: 52px; margin: 0 0 18px; font-size: 1.77rem; line-height: .95; letter-spacing: -.065em; }
.project-content p { min-height: 74px; color: #a7b3c8; font-size: .9rem; line-height: 1.58; margin: 0 0 22px; }
.project-content a { font-size: .84rem; }

.process-section { padding-bottom: 80px; }
.process-section h2 { max-width: 440px; margin-bottom: 66px; }
.process-line { position: relative; display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap: 24px; }
.process-line::before { content:""; position: absolute; top: 38px; left: 11%; right: 11%; border-top: 3px dotted rgba(255,255,255,.28); }
.process-step { position: relative; z-index: 1; text-align: center; }
.process-icon { width: 72px; height: 72px; margin: 0 auto 28px; border-radius: 999px; outline: 10px solid rgba(255,255,255,.04); }
.process-step h3 { font-size: 1.08rem; margin: 0 0 14px; letter-spacing: -.035em; }
.process-step p { color: #a5b0c4; line-height: 1.6; font-size: .87rem; width: min(100%,220px); margin: 0 auto; }

.cta-section { padding: 0 0 80px; }
.cta-card { min-height: 170px; display: grid; grid-template-columns: 1fr .9fr auto; align-items: center; gap: 34px; padding: clamp(30px,5vw,52px) clamp(30px,7vw,80px); border-radius: 14px; background: radial-gradient(circle at 78% 100%, rgba(55,92,255,.52), transparent 44%), linear-gradient(120deg,#e0202e 0%,#87205d 46%,#4051e6 100%); box-shadow: 0 28px 90px rgba(65,81,230,.18); }
.cta-card h2 { font-size: clamp(2rem,3.3vw,3.2rem); line-height: 1; letter-spacing: -.06em; margin: 0; }
.cta-card p { color: #f5f0fb; max-width: 350px; margin: 0; font-size: 1.06rem; line-height: 1.7; }
.btn-dark { color: #fff; background: #020713; min-width: 170px; }

.footer { color: #c0c9da; border-top: 1px solid rgba(255,255,255,.08); padding: 42px 0 28px; }
.footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.18fr; gap: 54px; }
.footer-brand .logo { margin-bottom: 18px; }
.footer p { color: #9aa6ba; line-height: 1.7; max-width: 300px; margin: 0; }
.footer h4 { color: #fff; margin: 0 0 18px; }
.footer-grid > div:not(.footer-brand) { display: flex; flex-direction: column; gap: 12px; }
.footer a, .footer span { color: #9faabe; transition: color .2s; }
.footer a:hover { color: #fff; }
.socials { display: flex; gap: 14px; margin-top: 22px; }
.socials a { width: 30px; height: 30px; display: grid; place-items: center; border: 1px solid rgba(255,255,255,.12); border-radius: 999px; }
.copyright { text-align: center; max-width: none !important; margin: 50px auto 0 !important; font-size: .88rem; }

.floating-stats {
  position: fixed;
  left: 18px;
  bottom: 18px;
  z-index: 25;
  display: none;
  gap: 10px;
  color: #dce5f5;
  font-size: .76rem;
  font-weight: 800;
}
.floating-stats span { display: inline-flex; align-items: center; gap: 7px; padding: 10px 12px; border: 1px solid rgba(255,255,255,.08); background: rgba(2,7,19,.72); backdrop-filter: blur(12px); border-radius: 999px; }

@media (width <= 1120px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-copy { max-width: 760px; }
  .phone-scene { justify-self: center; min-height: 600px; margin-top: -12px; }
  .services-grid { grid-template-columns: 1fr; }
  .section-copy { max-width: 680px; }
  .project-grid { grid-template-columns: repeat(2,minmax(0,1fr)); }
  .footer-grid { grid-template-columns: repeat(2,1fr); }
  .cta-card { grid-template-columns: 1fr; }
}

@media (width <= 980px) {
  .desktop-nav, .nav-cta { display: none; }
  .mobile-menu { display: grid; }
  .mobile-panel { display: block; max-height: 0; overflow: hidden; transition: max-height .28s ease; }
  .mobile-panel.is-open { max-height: 430px; }
  .nav { min-height: 72px; }
}

@media (width <= 760px) {
  .container { width: min(100% - 30px, 1160px); }
  .hero { padding-top: 46px; }
  .hero h1 { font-size: clamp(3.05rem, 14vw, 4.85rem); line-height: .94; }
  .hero-text { font-size: .98rem; line-height: 1.75; }
  .hero-actions { flex-direction: column; align-items: stretch; }
  .btn { width: 100%; min-height: 54px; }
  .trust-points { flex-direction: column; align-items: flex-start; gap: 16px; margin-top: 42px; }
  .phone-scene { width: 420px; min-height: 500px; transform: scale(.82); transform-origin: top center; margin: -4px auto -78px; }
  .phone-front { left: 22px; }
  .phone-back { right: 0; }
  .client-strip { padding-top: 38px; }
  .client-logos { grid-template-columns: repeat(2,1fr); gap: 16px 24px; }
  .client-logos > span { min-height: 52px; }
  .client-logos > span:last-child { grid-column: 1 / -1; }
  .dish-logo { font-size: 2.45rem; }
  .somos-logo { font-size: 2.55rem; }
  .nomibox-logo { font-size: 1.88rem; }
  .variv-logo { font-size: 1.72rem; }
  .section { padding-top: 72px; }
  .section-copy h2, .work h2, .process-section h2 { font-size: clamp(2.25rem, 11vw, 3.15rem); }
  .service-cards, .process-line, .footer-grid { grid-template-columns: 1fr; }
  .service-card { padding: 28px 24px; }
  .service-card h3, .service-card p, .service-card .mini-link { margin-left: 0; }
  .service-card h3 { margin-top: 20px; }
  .work-head { align-items: flex-start; }
  .slider-buttons { display: none; }
  .project-grid { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 2px 14px 18px 0; margin-right: -15px; }
  .project-card { min-width: min(83vw, 320px); scroll-snap-align: start; }
  .process-line::before { display: none; }
  .process-section h2 { margin-bottom: 42px; }
  .process-step { display: grid; grid-template-columns: 72px 1fr; text-align: left; column-gap: 20px; align-items: center; }
  .process-icon { margin: 0; grid-row: span 2; }
  .process-step p { margin: 0; width: auto; }
  .cta-card { padding: 30px 22px; gap: 24px; }
  .footer-grid { gap: 34px; }
  .copyright { text-align: left; }
}

@media (width <= 480px) {
  .container { width: min(100% - 26px, 1160px); }
  .logo { font-size: 1.22rem; }
  .eyebrow, .section-kicker { font-size: .68rem; line-height: 1.55; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(2.95rem, 15vw, 4.2rem); }
  .phone-scene { width: 360px; min-height: 462px; transform: scale(.76); margin-left: calc(50% - 180px); margin-bottom: -88px; }
  .phone-front { left: 0; }
  .phone-back { right: -54px; }
  .service-card { min-height: auto; }
  .project-card { min-width: 86vw; }
  .cta-card h2 { font-size: 2.1rem; }
}

@media (width <= 370px) {
  .phone-scene { transform: scale(.68); margin-bottom: -120px; }
  .hero h1 { font-size: 2.75rem; }
}
